{
  "info": {
    "name": "Fresh Ticketing System",
    "description": "API collection for the fresh-build ticketing system (testing/teaching project).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3010" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"admin123\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "List Tickets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tickets"
          }
        },
        {
          "name": "Get Ticket by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tickets/1"
          }
        },
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"PC not connecting to the internet\",\n  \"description\": \"Wi-Fi keeps dropping every 5 minutes\",\n  \"category\": \"network\",\n  \"priority\": \"medium\",\n  \"custom_values\": {}\n}"
            },
            "url": "{{baseUrl}}/api/tickets"
          }
        },
        {
          "name": "Update Ticket Status (workflow)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"assigned\",\n  \"assigned_to\": 2\n}" },
            "url": "{{baseUrl}}/api/tickets/1"
          }
        },
        {
          "name": "Set Remote Tool Session",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"remote_tool\": \"AnyDesk\",\n  \"remote_session_link\": \"anydesk:987654321\"\n}" },
            "url": "{{baseUrl}}/api/tickets/1"
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"comment\": \"Checked, waiting for user confirmation.\"\n}" },
            "url": "{{baseUrl}}/api/tickets/1/comments"
          }
        },
        {
          "name": "Add Work Log (for payroll)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"minutes_spent\": 45,\n  \"note\": \"Remote troubleshooting via AnyDesk\"\n}" },
            "url": "{{baseUrl}}/api/tickets/1/worklog"
          }
        }
      ]
    },
    {
      "name": "Custom Fields",
      "item": [
        {
          "name": "List Custom Fields",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/custom-fields"
          }
        },
        {
          "name": "Create Custom Field",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"antivirus_used\",\n  \"label\": \"Antivirus Used\",\n  \"field_type\": \"dropdown\",\n  \"options\": [\"Windows Defender\", \"Avast\", \"Kaspersky\", \"None\"],\n  \"applies_to_category\": \"virus\",\n  \"required\": true\n}"
            },
            "url": "{{baseUrl}}/api/custom-fields"
          }
        }
      ]
    },
    {
      "name": "Payroll",
      "item": [
        {
          "name": "Payroll Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/payroll/summary"
          }
        },
        {
          "name": "List Agents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/payroll/agents"
          }
        }
      ]
    }
  ]
}
